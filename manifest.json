{
  "manifest_version": 3,
  "name": "Tracely – Create Step-by-Step Guides Instantly",
  "description": "Automatically capture clicks and turn any workflow into a clean, shareable guide.",
  "version": "1.1.1",
  "version_name": "1.1.1 – Remove All groups from group selector; fix Azure screenshot upload",
  "homepage_url": "https://tracely.uk",
  "minimum_chrome_version": "114",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "sidePanel",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Tracely sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/config.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/pageBridge.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
